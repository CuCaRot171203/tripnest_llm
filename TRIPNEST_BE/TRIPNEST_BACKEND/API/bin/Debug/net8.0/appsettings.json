{
  "Jwt": {
    "Key": "REPLACE_WITH_LONG_SECRET_FROM_ENV_OR_KEYVAULT",
    "Issuer": "TripnestApi",
    "Audience": "TripnestClient",
    "AccessTokenExpireMinutes": 15,
    "RefreshTokenExpireDays": 30
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=tripnest;User=root;Password=123456"
  },
  "Vector": {
    "Provider": "openai", // "openai" or "fallback"
    "OpenAI": {
      "ApiKey": "", // <- move to env / secret store
      "BaseUrl": "https://api.openai.com/v1",
      "Model": "text-embedding-3-large"
    }
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": "587",
    "Username": "smtp-user@example.com", // <- prefer env
    "Password": "", // <- prefer env / KeyVault
    "EnableSsl": "true",
    "FromAddress": "no-reply@tripnest.example",
    "FromDisplayName": "Tripnest"
  },

  "HttpClient": {
    "DefaultTimeoutSeconds": 30,
    "VectorClientTimeoutSeconds": 45
  },
  "RetryPolicy": {
    "MaxRetries": 3,
    "InitialDelayMs": 500
  },

  "Worker": {
    "Reminder": {
      "DefaultDaysAhead": 1,
      "MaxDaysAheadAllowed": 30
    },
    "Indexing": {
      "Enabled": true,
      "BatchSize": 50
    }
  },
  "Storage": {
    "Provider": "local", // "s3" | "cloudinary" | "local"
    "S3": {
      "Bucket": "",
      "Region": "",
      "AccessKey": "",
      "SecretKey": ""
    },
    "Cloudinary": {
      "CloudName": "",
      "ApiKey": "",
      "ApiSecret": ""
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://app.tripnest.example"
    ]
  },
  "Hangfire": {
    "ConnectionStringName": "DefaultConnection",
    "UseHangfire": false
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "EmailTemplates": {
    "BookingReminderSubject": "Reminder: Your upcoming check-in on {CheckinDate}",
    "BookingReminderBody": "Hi {FullName},\n\nThis is a reminder for your booking (#{BookingId}) at {PropertyTitle} on {CheckinDate}.\n\nSee you soon,\nTripnest Team"
  },

  "FeatureFlags": {
    "EnableEmbeddings": true,
    "EnableEmailSending": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Llm": {
    "BaseUrl": "http://localhost:8000/",
    "HttpClientTimeoutSeconds": 100,
    "PerAttemptTimeoutSeconds": 15,
    "RetryCount": 3,
    "RetryBackoffMs": [ 200, 500, 1000 ],
    "CircuitBreakerFailures": 3,
    "CircuitBreakerDurationSeconds": 30
  },
  "AllowedHosts": "*"
}